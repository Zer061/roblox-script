print("[MH] loaded")

-- ================= AIM / WALL (ghi de MouseLoc) =================
local Def=workspace:FindFirstChild("Defenders")
local function nearestEnemy()
 if not hrp then return nil end
 local best,bd=nil,math.huge
 for _,m in ipairs(workspace:GetDescendants()) do
  if m:IsA("Model") and m~=char then
   local h=m:FindFirstChildOfClass("Humanoid")
   local r=m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Torso") or m.PrimaryPart
   if h and h.Health>0 and r then
    local skip=false
    if Def and m:IsDescendantOf(Def) then skip=true end
    if P:GetPlayerFromCharacter(m) then skip=true end
    if not skip then
     local d=(r.Position-hrp.Position).Magnitude
     if d<bd then bd=d best=r end
    end
   end
  end
 end
 return best
end

local function defaultAim()
 local m=plr:GetMouse()
 pcall(function() m.TargetFilter=workspace.Map.Scenery end)
 return m.Hit.Position, m.Target
end

-- muc tieu hien tai (cap nhat dinh ky de do nang)
local curTarget=nil
task.spawn(function()
 while true do
  if aim then curTarget=nearestEnemy() else curTarget=nil end
  task.wait(0.08)
 end
end)

local hooked
local function applyAim()
 local t=char and char:FindFirstChildOfClass("Tool")
 if not t then return end
 local ml=t:FindFirstChild("MouseLoc")
 if not ml or ml==hooked then return end
 hooked=ml
 ml.OnClientInvoke=function()
  if aim then
   local e=curTarget or nearestEnemy()
   if e and e.Parent then return e.Position, e end
  end
  return defaultAim()
 end
end

RS.Heartbeat:Connect(function()
 pcall(applyAim)
end)

-- xoay camera nham vao quai gan nhat khi bat Aim
RS.RenderStepped:Connect(function()
 if aim and curTarget and curTarget.Parent then
  local cam=workspace.CurrentCamera
  local goal=CFrame.new(cam.CFrame.Position, curTarget.Position)
  cam.CFrame=cam.CFrame:Lerp(goal,0.35)
 end
end)
